# Database Configuration
DATABASE_URL=postgresql://alphaloop_sys:your_sys_password@alphaloop-database:5432/alphaloop_market

# Cloud API Configuration (for data retrieval)
CLOUD_API_URL=https://your-cloud-api.com/api/v1
CLOUD_API_KEY=your_cloud_api_key

# Logging
LOG_LEVEL=INFO

# Market Data Configuration
MARKET_DATA_INTERVAL=10
MARKET_DATABASE=alphaloop_market

# Cloud Sync Configuration (for local deployment)
CLOUD_SYNC_ENABLED=true
CLOUD_SYNC_INTERVAL=300

# Path Configuration
ALPHALOOP_HOME=/opt/alphaloop
