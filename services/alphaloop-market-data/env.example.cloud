# Database Configuration
DATABASE_URL=postgresql://alphaloop_sys:your_sys_password@alphaloop-database:5432/alphaloop_market

# Logging
LOG_LEVEL=INFO

# Market Data Configuration
MARKET_DATA_INTERVAL=10
MARKET_DATABASE=alphaloop_market

# Cloud Sync Configuration (disabled for cloud deployment)
CLOUD_SYNC_ENABLED=false

# Path Configuration
ALPHALOOP_HOME=/opt/alphaloop
