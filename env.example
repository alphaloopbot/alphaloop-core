# Service Configuration
SERVICE_HOST=localhost
SERVICE_PORT=8000
SERVICE_URL=http://localhost:8000  # Optional override

# Database Configuration
DB_HOST=database
DB_PORT=5432
DB_NAME=alphaloop
DB_USER=postgres
DB_PASSWORD=your_password
DATABASE_URL=postgresql://postgres:your_password@database:5432/alphaloop

# API Configuration
API_KEY=your-api-key-here
LOG_LEVEL=INFO
ENVIRONMENT=development

# Trading Configuration
DEFAULT_CURRENCY=USDT  # Default currency for market data and trading operations



# Docker Configuration
VERSION=latest

# Deployment Examples
# Docker Compose: Use DB_HOST=database, DB_PORT=5432
# External Service: Use DB_HOST=your-external-host, DB_PORT=5432
# Local Development: Use DB_HOST=localhost, DB_PORT=5432
