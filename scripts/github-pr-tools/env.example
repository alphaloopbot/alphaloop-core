# GitHub Personal Access Token for PR Tools
#
# To get a GitHub token:
# 1. Go to GitHub.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
# 2. Click "Generate new token (classic)"
# 3. Give it a name like "AlphaLoop PR Tools"
# 4. Select scopes: "repo" (for private repos) or "public_repo" (for public repos)
# 5. Copy the generated token and paste it below
#
# Copy this file to .env and replace the placeholder with your actual token:
# cp env.example .env
# Then edit .env and replace YOUR_GITHUB_TOKEN_HERE with your actual token

GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# Optional: GitHub repository details (if different from current repo)
# GITHUB_REPO_OWNER=your-username
# GITHUB_REPO_NAME=alphaloop-core
